---
interface Props {
  title: string;
  description?: string;
  image?: string;
  article?: {
    publishedTime: string;
    modifiedTime: string;
    author: string;
    section: string;
    tags: string[];
  };
}

const {
  title,
  description = 'Descubre herramientas de inteligencia artificial comparadas y analizadas. Guías prácticas, tutoriales y comparativas.',
  image = '/og-image.svg',
  article,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://ia-tools-web.pages.dev';
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const ogImage = image.startsWith('http') ? image : new URL(image, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#0369a1">
  <meta name="author" content="IA Tools Hub">
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
  
  <link rel="canonical" href={canonicalURL}>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='4' fill='%230369a1'/%3E%3Ctext x='50%25' y='55%25' dominant-baseline='middle' text-anchor='middle' font-size='14' font-weight='600' fill='white'%3EIA%3C/text%3E%3C/svg%3E">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <title>{title}</title>

  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={article ? 'article' : 'website'}>
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:image" content={ogImage}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:locale" content="es_ES">
  <meta property="og:site_name" content="IA Tools Hub">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImage}>

  {article && (
    <>
      <meta property="article:published_time" content={article.publishedTime}>
      <meta property="article:modified_time" content={article.modifiedTime}>
      <meta property="article:section" content={article.section}>
      {article.tags.map((tag) => <meta property="article:tag" content={tag} />)}
    </>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'IA Tools Hub',
    url: siteUrl,
    description: 'Guías y comparativas de herramientas de inteligencia artificial.',
    potentialAction: {
      '@type': 'SearchAction',
      target: `${siteUrl}/blog?q={search_term_string}`,
      'query-input': 'required name=search_term_string',
    },
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'IA Tools Hub',
    url: siteUrl,
    logo: `${siteUrl}/logo.svg`,
  })} />
</head>

<body class="bg-hub-bg text-hub-darkMid font-body antialiased">
  <slot />

  <footer class="bg-hub-dark text-hub-grayLight py-16 mt-20 border-t border-hub-darkLight">
    <div class="max-w-5xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12">
        <div class="md:col-span-4">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xl font-bold text-white">IA Tools</span>
            <span class="text-hub-accent">Hub</span>
          </div>
          <p class="text-sm leading-relaxed mb-6">
            Descubre herramientas de inteligencia artificial con guías, comparativas y análisis prácticos para elegir mejor.
          </p>
          <a href="/mejores-herramientas-ia" class="inline-block px-4 py-2 bg-hub-accent text-white text-sm font-medium rounded-lg hover:bg-hub-accentLight transition-colors">
            Ver mejores herramientas IA
          </a>
        </div>
        
        <div class="md:col-span-2">
          <h4 class="text-white font-medium mb-4 text-sm tracking-wide">Navegación</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/" class="hover:text-white transition-colors">Inicio</a></li>
            <li><a href="/blog" class="hover:text-white transition-colors">Herramientas IA</a></li>
            <li><a href="/comparativas" class="hover:text-white transition-colors">Comparativas</a></li>
            <li><a href="/guias" class="hover:text-white transition-colors">Guías</a></li>
          </ul>
        </div>
        
        <div class="md:col-span-3">
          <h4 class="text-white font-medium mb-4 text-sm tracking-wide">Guías clave</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/mejores-herramientas-ia" class="hover:text-white transition-colors">Mejores herramientas IA</a></li>
            <li><a href="/ia-para-ganar-dinero" class="hover:text-white transition-colors">IA para ganar dinero</a></li>
            <li><a href="/herramientas-ia-gratis" class="hover:text-white transition-colors">Herramientas IA gratis</a></li>
            <li><a href="/ia-para-negocios" class="hover:text-white transition-colors">IA para negocios</a></li>
          </ul>
        </div>
        
        <div class="md:col-span-3">
          <h4 class="text-white font-medium mb-4 text-sm tracking-wide">Legal</h4>
          <ul class="space-y-3 text-sm">
            <li><a href="/aviso-legal" class="hover:text-white transition-colors">Aviso legal</a></li>
            <li><a href="/politica-privacidad" class="hover:text-white transition-colors">Política de privacidad</a></li>
            <li><a href="/politica-cookies" class="hover:text-white transition-colors">Política de cookies</a></li>
            <li><a href="/terminos-uso" class="hover:text-white transition-colors">Términos de uso</a></li>
          </ul>
        </div>
      </div>
      
      <div class="border-t border-hub-darkLight mt-12 pt-8 text-sm text-center text-hub-slate">
        <p>&copy; {new Date().getFullYear()} IA Tools Hub. Todos los derechos reservados.</p>
      </div>
    </div>
  </footer>

  <script is:inline>
    window.dataLayer = window.dataLayer || [];

    document.addEventListener('click', function (event) {
      const link = event.target.closest('[data-affiliate-tool]');
      if (!link) return;

      window.dataLayer.push({
        event: 'affiliate_click',
        affiliate_tool: link.dataset.affiliateTool,
        affiliate_name: link.dataset.affiliateName,
        affiliate_program: link.dataset.affiliateProgram,
        affiliate_tracking_id: link.dataset.affiliateTrackingId,
        affiliate_placement: link.dataset.affiliatePlacement,
        affiliate_url: link.href,
        page_path: window.location.pathname,
      });
    });
  </script>
</body>
</html>
