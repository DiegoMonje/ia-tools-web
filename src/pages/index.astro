---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HubHero from '../components/HubHero.astro';
import FeaturedToolCard from '../components/FeaturedToolCard.astro';
import CategoryHubCard from '../components/CategoryHubCard.astro';
import RankingCard from '../components/RankingCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featuredPost = sortedPosts.find(post => post.data.featured) || sortedPosts[0];
const latestPosts = sortedPosts.slice(0, 6);

const categories = [
  { name: 'Chatbots IA', slug: 'ia-de-texto', count: 8 },
  { name: 'Generadores de Imágenes', slug: 'ia-de-imagen', count: 6 },
  { name: 'Automatización', slug: 'productividad', count: 4 },
  { name: 'Productividad', slug: 'productividad', count: 5 },
  { name: 'Escritura con IA', slug: 'ia-de-texto', count: 4 },
  { name: 'Marketing con IA', slug: 'productividad', count: 3 },
  { name: 'Programación', slug: 'ia-de-codigo', count: 5 },
  { name: 'Comparativas', slug: 'ia-de-texto', count: 10 },
];

const quickStart = [
  {
    title: 'Quiero elegir una herramienta IA',
    description: 'Ranking principal con opciones para escribir, crear imágenes, automatizar tareas, programar y trabajar más rápido.',
    href: '/mejores-herramientas-ia',
    cta: 'Ver ranking recomendado',
  },
  {
    title: 'Quiero ganar dinero con IA',
    description: 'Ideas prácticas para convertir herramientas de IA en contenidos, servicios digitales, afiliación y proyectos online.',
    href: '/blog/mejor-ia-para-ganar-dinero-2026',
    cta: 'Ver estrategias rentables',
  },
  {
    title: 'Soy autónomo o tengo un negocio',
    description: 'Herramientas para ahorrar tiempo, crear propuestas, responder clientes y mejorar la productividad diaria.',
    href: '/blog/ia-para-autonomos-2026',
    cta: 'Ver IA para negocios',
  },
];

const topTools = [
  { title: 'ChatGPT', category: 'Chatbot', description: 'La opción más versátil para escribir, idear, resumir y crear contenido', href: '/blog/mejor-ia-para-escribir-articulos-2026', rating: '4.8' },
  { title: 'Claude', category: 'Chatbot', description: 'Muy bueno para analizar textos largos y mejorar calidad editorial', href: '/blog/chatgpt-vs-claude-2026', rating: '4.7' },
  { title: 'Canva IA', category: 'Diseño', description: 'Ideal para crear imágenes, posts, pines y recursos visuales rápidamente', href: '/mejores-herramientas-ia', rating: '4.5' },
  { title: 'GitHub Copilot', category: 'Código', description: 'Ayuda a programar, documentar y acelerar tareas técnicas', href: '/mejores-herramientas-ia', rating: '4.6' },
  { title: 'Midjourney', category: 'Imágenes', description: 'Herramienta potente para creatividad visual y contenido de marca', href: '/mejores-herramientas-ia', rating: '4.9' },
];

const seoCategories = [
  {
    title: 'Herramientas de IA gratis',
    href: '/herramientas-ia-gratis',
    keyword: 'IA gratis',
    description: 'Selección de herramientas gratuitas para escribir, crear imágenes, resumir textos, programar y automatizar tareas sin empezar pagando.'
  },
  {
    title: 'IA para negocios',
    href: '/ia-para-negocios',
    keyword: 'IA empresarial',
    description: 'Recursos para autónomos, pymes y empresas que quieren ahorrar tiempo, captar clientes y mejorar procesos usando inteligencia artificial.'
  },
  {
    title: 'IA para ganar dinero',
    href: '/blog/mejor-ia-para-ganar-dinero-2026',
    keyword: 'monetización con IA',
    description: 'Ideas prácticas para usar herramientas de IA en contenidos, afiliación, automatizaciones, servicios digitales y proyectos online.'
  },
  {
    title: 'IA para escribir artículos',
    href: '/blog/mejor-ia-para-escribir-articulos-2026',
    keyword: 'contenido con IA',
    description: 'Guía para elegir herramientas de IA que ayudan a crear artículos, estructuras SEO, títulos, FAQs y contenidos monetizables.'
  },
];

const comparisonTools = [
  { title: 'ChatGPT vs Claude', category: 'Comparativa', href: '/blog/chatgpt-vs-claude-2026', badge: 'Popular' },
  { title: 'Mejor IA para escribir artículos', category: 'Contenido SEO', href: '/blog/mejor-ia-para-escribir-articulos-2026', badge: 'Guía práctica' },
  { title: 'Mejor IA para ganar dinero', category: 'Monetización', href: '/blog/mejor-ia-para-ganar-dinero-2026', badge: 'Negocio' },
  { title: 'IA para autónomos', category: 'Productividad', href: '/blog/ia-para-autonomos-2026', badge: 'Negocios' },
];
---

<Layout
  title="Mejores herramientas de IA 2026: rankings, comparativas y guías para ganar tiempo"
  description="Compara herramientas de inteligencia artificial para escribir, crear contenido, automatizar tareas, trabajar mejor y encontrar opciones con potencial de monetización."
>
  <Header />
  
  <main>
    <!-- Hero Section -->
    <HubHero categories={categories} />

    <!-- Primary Conversion Section -->
    <section class="py-12 bg-hub-dark text-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-7">
            <span class="inline-block text-sm font-semibold uppercase tracking-wider text-hub-grayLight mb-3">Empieza aquí</span>
            <h2 class="text-3xl md:text-4xl font-bold mb-4">Elige la herramienta IA correcta según tu objetivo</h2>
            <p class="text-hub-grayLight leading-relaxed mb-6">
              No pierdas tiempo probando decenas de aplicaciones. Hemos organizado las mejores herramientas de IA por uso: escribir, diseñar, automatizar, programar, mejorar negocios y crear ingresos online.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="/mejores-herramientas-ia" class="px-6 py-3 bg-hub-accent text-white rounded-lg font-semibold hover:bg-hub-accentLight transition-colors text-center">
                Ver mejores herramientas IA
              </a>
              <a href="/blog/chatgpt-vs-claude-2026" class="px-6 py-3 bg-white text-hub-dark rounded-lg font-semibold hover:bg-hub-grayLighter transition-colors text-center">
                Comparar ChatGPT vs Claude
              </a>
            </div>
          </div>
          <div class="lg:col-span-5 bg-hub-darkLight rounded-2xl p-6 border border-hub-slate">
            <h3 class="text-xl font-bold mb-4">Ruta rápida</h3>
            <ul class="space-y-3 text-sm text-hub-grayLight">
              <li>✅ Si quieres escribir: empieza por ChatGPT o Claude.</li>
              <li>✅ Si quieres vender servicios: revisa IA para autónomos.</li>
              <li>✅ Si quieres monetizar: empieza por herramientas IA para ganar dinero.</li>
              <li>✅ Si no sabes qué elegir: mira el ranking completo.</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section class="py-12 bg-hub-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-3xl mb-8">
          <span class="text-sm font-semibold uppercase tracking-wider text-hub-accent">Decide más rápido</span>
          <h2 class="text-2xl md:text-3xl font-bold text-hub-dark mt-2 mb-3">¿Qué quieres conseguir con la IA?</h2>
          <p class="text-hub-slate leading-relaxed">
            Empieza por tu objetivo principal. Cada ruta te lleva a una guía o ranking pensado para tomar una decisión y probar herramientas útiles sin perder tiempo.
          </p>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {quickStart.map((item) => (
            <a href={item.href} class="group block bg-hub-bg border border-hub-grayLighter hover:border-hub-accent rounded-xl p-6 transition-colors">
              <h3 class="text-xl font-bold text-hub-dark group-hover:text-hub-accent transition-colors mb-3">{item.title}</h3>
              <p class="text-sm text-hub-slate leading-relaxed mb-5">{item.description}</p>
              <span class="inline-flex items-center text-sm font-semibold text-hub-accent">{item.cta} →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Featured Tools Section -->
    <section class="py-12 bg-hub-white border-t border-hub-grayLighter">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8 gap-4">
          <h2 class="text-2xl font-bold text-hub-dark">Análisis y guías destacadas</h2>
          <a href="/mejores-herramientas-ia" class="text-sm font-medium text-hub-accent hover:underline">
            Comparar herramientas IA →
          </a>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          <FeaturedToolCard 
            title={featuredPost.data.title}
            description={featuredPost.data.description}
            category={featuredPost.data.category}
            image={featuredPost.data.heroImage}
            href={`/blog/${featuredPost.slug}`}
            cta="Ver herramienta recomendada"
            featured
          />
          {sortedPosts.slice(1, 5).map((post) => (
            <FeaturedToolCard 
              title={post.data.title}
              description={post.data.description}
              category={post.data.category}
              image={post.data.heroImage}
              href={`/blog/${post.slug}`}
              cta="Ver guía"
            />
          ))}
        </div>
      </div>
    </section>
    
    <!-- Categories Section -->
    <section class="py-12 bg-hub-bg">
      <div class="max-w-5xl mx-auto px-6">
        <h2 class="text-2xl font-bold text-hub-dark mb-8 text-center">Explorar por categoría</h2>
        <CategoryHubCard categories={categories} />
      </div>
    </section>

    <!-- SEO Landing Pages Section -->
    <section class="py-14 bg-hub-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="max-w-3xl mb-8">
          <span class="text-sm font-semibold uppercase tracking-wider text-hub-accent">Guías estratégicas</span>
          <h2 class="text-2xl md:text-3xl font-bold text-hub-dark mt-2 mb-3">
            Herramientas de IA por objetivo
          </h2>
          <p class="text-hub-slate leading-relaxed">
            No todas las herramientas sirven para lo mismo. Empieza por el objetivo que quieres conseguir y encuentra guías pensadas para elegir rápido, ahorrar tiempo y aplicar IA con sentido práctico.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-5">
          {seoCategories.map((item) => (
            <a href={item.href} class="group block bg-hub-bg border border-hub-grayLighter hover:border-hub-accent rounded-xl p-6 transition-colors">
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  <span class="inline-block text-xs font-semibold uppercase tracking-wider text-hub-accent mb-2">
                    {item.keyword}
                  </span>
                  <h3 class="text-xl font-bold text-hub-dark group-hover:text-hub-accent transition-colors">
                    {item.title}
                  </h3>
                </div>
                <span class="text-hub-accent text-xl">→</span>
              </div>
              <p class="text-sm text-hub-slate leading-relaxed">
                {item.description}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Rankings Section -->
    <section class="py-12 bg-hub-bg">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8 gap-4">
          <h2 class="text-2xl font-bold text-hub-dark">Top herramientas IA para empezar</h2>
          <a href="/mejores-herramientas-ia" class="text-sm font-semibold text-hub-accent hover:underline">
            Ver ranking completo →
          </a>
        </div>
        
        <div class="grid md:grid-cols-2 gap-4">
          {topTools.map((tool, index) => (
            <RankingCard 
              rank={index + 1}
              title={tool.title}
              category={tool.category}
              description={tool.description}
              href={tool.href}
            />
          ))}
        </div>
      </div>
    </section>
    
    <!-- Latest Articles Section -->
    <section class="py-12 bg-hub-white">
      <div class="max-w-5xl mx-auto px-6">
        <div class="flex items-center justify-between mb-8 gap-4">
          <h2 class="text-2xl font-bold text-hub-dark">Últimos artículos para aprender y decidir</h2>
          <a href="/blog" class="text-sm font-medium text-hub-accent hover:underline">
            Ver todos los artículos →
          </a>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      </div>
    </section>
    
    <!-- Comparison CTA -->
    <section class="py-12 bg-hub-accent">
      <div class="max-w-5xl mx-auto px-6 text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Compara antes de pagar por una herramienta IA</h2>
        <p class="text-hub-grayLight mb-8 max-w-2xl mx-auto">
          Revisa guías y comparativas antes de elegir. Te ayudamos a decidir qué herramienta encaja mejor con tu trabajo, negocio o proyecto online.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          {comparisonTools.map((tool) => (
            <a href={tool.href} class="px-5 py-3 bg-hub-white text-hub-accent font-medium hover:bg-hub-grayLighter transition-colors rounded-lg">
              {tool.title}
            </a>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Newsletter -->
    <section class="py-16 bg-hub-white">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <span class="text-sm font-semibold uppercase tracking-wider text-hub-accent">Recurso gratuito</span>
        <h2 class="text-2xl md:text-3xl font-bold text-hub-dark mt-2 mb-3">Descarga la lista de herramientas IA para trabajar más rápido</h2>
        <p class="text-hub-slate mb-8">
          Recibe una selección práctica de herramientas IA para escribir, crear contenido, automatizar tareas y encontrar oportunidades de monetización.
        </p>
        <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
          <input 
            type="email" 
            placeholder="Tu email"
            class="flex-1 px-5 py-3 bg-hub-white border border-hub-grayLighter focus:border-hub-accent focus:outline-none transition-colors rounded-lg"
            required
          />
          <button 
            type="submit"
            class="px-8 py-3 bg-hub-accent text-white font-medium hover:bg-hub-accentLight transition-colors rounded-lg whitespace-nowrap"
          >
            Descargar gratis
          </button>
        </form>
        <p class="text-xs text-hub-gray mt-4">
          Sin spam. Solo guías, comparativas y recursos útiles. Puedes darte de baja cuando quieras.
        </p>
      </div>
    </section>
  </main>
</Layout>