---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const guidePosts = posts
  .filter((post) => {
    const text = `${post.data.title} ${post.data.description} ${post.data.tags.join(' ')}`.toLowerCase();
    return text.includes('guía') || text.includes('guia') || text.includes('tutorial') || text.includes('cómo') || text.includes('como');
  })
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Guías de inteligencia artificial - IA Tools Hub"
  description="Guías prácticas para usar herramientas de inteligencia artificial en productividad, contenido, automatización, programación y negocios."
>
  <Header />

  <main class="py-12 bg-hub-bg">
    <div class="max-w-5xl mx-auto px-6">
      <header class="mb-10">
        <h1 class="text-3xl font-bold text-hub-dark mb-3">Guías de inteligencia artificial</h1>
        <p class="text-hub-slate text-lg max-w-3xl">
          Tutoriales y recursos prácticos para aplicar IA en tareas reales sin perder tiempo con teoría innecesaria.
        </p>
      </header>

      {guidePosts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {guidePosts.map((post) => (
            <ArticleCard post={post} />
          ))}
        </div>
      ) : (
        <div class="bg-hub-white border border-hub-grayLighter rounded-lg p-8">
          <p class="text-hub-slate">Todavía no hay guías publicadas. Puedes ver todos los artículos en <a href="/blog" class="text-hub-accent hover:underline">Herramientas IA</a>.</p>
        </div>
      )}
    </div>
  </main>
</Layout>
