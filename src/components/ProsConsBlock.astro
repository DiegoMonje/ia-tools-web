---
interface Props {
  title?: string;
}

const { title = 'Análisis' } = Astro.props;
---

<div class="pros-cons-block grid md:grid-cols-2 gap-6 my-8">
  <div class="pros bg-green-50 border border-green-200 rounded-lg p-5">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-hub-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <h3 class="text-lg font-semibold text-hub-dark">Ventajas</h3>
    </div>
    <ul class="space-y-3">
      <slot name="pros">
        <li class="flex items-start gap-2 text-hub-slate">
          <svg class="w-4 h-4 text-hub-success mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>Ventaja 1</span>
        </li>
      </slot>
    </ul>
  </div>
  
  <div class="cons bg-red-50 border border-red-200 rounded-lg p-5">
    <div class="flex items-center gap-2 mb-4">
      <svg class="w-5 h-5 text-hub-error" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
      <h3 class="text-lg font-semibold text-hub-dark">Desventajas</h3>
    </div>
    <ul class="space-y-3">
      <slot name="cons">
        <li class="flex items-start gap-2 text-hub-slate">
          <svg class="w-4 h-4 text-hub-error mt-1 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
          <span>Desventaja 1</span>
        </li>
      </slot>
    </ul>
  </div>
</div>