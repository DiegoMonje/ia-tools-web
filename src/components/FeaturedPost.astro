---
interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      description: string;
      category: string;
      pubDate: Date;
      readTime: string;
      author: string;
      heroImage?: string;
    };
  };
  size?: 'large' | 'medium';
}

const { post, size = 'large' } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
};
---

{size === 'large' ? (
  <article class="featured-article group">
    <a href={`/blog/${post.slug}`} class="block">
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <div class="order-2 md:order-1">
          <span class="inline-block text-xs font-medium uppercase tracking-widest text-editorial-accent mb-3">
            {post.data.category}
          </span>
          <h2 class="font-serif text-3xl md:text-4xl font-semibold text-editorial-dark leading-tight mb-4 group-hover:text-editorial-accent transition-colors">
            {post.data.title}
          </h2>
          <p class="text-editorial-gray leading-relaxed mb-5 text-lg">
            {post.data.description}
          </p>
          <div class="flex items-center gap-4 text-sm text-editorial-grayLight">
            <span class="font-medium text-editorial-dark">{post.data.author}</span>
            <span class="w-1 h-1 bg-editorial-grayLight rounded-full"></span>
            <span>{formatDate(post.data.pubDate)}</span>
            <span class="w-1 h-1 bg-editorial-grayLight rounded-full"></span>
            <span>{post.data.readTime} de lectura</span>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <div class="aspect-[4/3] bg-editorial-cream overflow-hidden">
            {post.data.heroImage ? (
              <img 
                src={post.data.heroImage} 
                alt={post.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
            ) : (
              <div class="w-full h-full flex items-center justify-center bg-editorial-grayLighter">
                <svg class="w-16 h-16 text-editorial-grayLight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
              </div>
            )}
          </div>
        </div>
      </div>
    </a>
  </article>
) : (
  <article class="featured-article-secondary group">
    <a href={`/blog/${post.slug}`} class="block">
      <div class="flex gap-5 items-start">
        <div class="flex-1">
          <span class="inline-block text-xs font-medium uppercase tracking-widest text-editorial-accent mb-2">
            {post.data.category}
          </span>
          <h3 class="font-serif text-xl font-semibold text-editorial-dark leading-snug mb-2 group-hover:text-editorial-accent transition-colors">
            {post.data.title}
          </h3>
          <p class="text-editorial-gray text-sm leading-relaxed line-clamp-2 mb-3">
            {post.data.description}
          </p>
          <div class="flex items-center gap-3 text-xs text-editorial-grayLight">
            <span>{formatDate(post.data.pubDate)}</span>
            <span class="w-1 h-1 bg-editorial-grayLight rounded-full"></span>
            <span>{post.data.readTime}</span>
          </div>
        </div>
        <div class="w-24 h-24 flex-shrink-0 bg-editorial-cream overflow-hidden">
          {post.data.heroImage ? (
            <img 
              src={post.data.heroImage} 
              alt={post.data.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          ) : (
            <div class="w-full h-full flex items-center justify-center bg-editorial-grayLighter">
              <svg class="w-8 h-8 text-editorial-grayLight" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
              </svg>
            </div>
          )}
        </div>
      </div>
    </a>
  </article>
)}