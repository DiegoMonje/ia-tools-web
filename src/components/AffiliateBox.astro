---
import { affiliateDisclosure } from '../data/affiliateTools';
const { tool } = Astro.props;
---

<div class="border border-hub-grayLighter rounded-xl p-6 bg-hub-bg">
  <h3 class="text-lg font-bold mb-2">{tool.name}</h3>
  <p class="text-sm text-hub-slate mb-2">{tool.bestFor}</p>
  <p class="text-sm mb-3"><strong>Precio:</strong> {tool.price}</p>
  <p class="text-sm mb-4"><strong>Valoración:</strong> {tool.rating} ⭐</p>
  
  <a href={tool.affiliateUrl} target="_blank" rel="nofollow sponsored" class="inline-block px-5 py-3 bg-hub-accent text-white rounded-lg font-medium hover:bg-hub-accentLight">
    {tool.cta}
  </a>

  <p class="text-xs text-hub-gray mt-4">{affiliateDisclosure}</p>
</div>